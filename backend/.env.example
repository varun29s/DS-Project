# ---- Copy to .env and fill in your values ----

# Supabase Postgres connection string.
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Replace [YOUR-PASSWORD] with your DB password. The "Session pooler" (port 5432)
# is recommended for this sync (psycopg2) setup.
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres

# Secret used to sign JWTs. Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Supabase Storage. 
# SUPABASE_URL: Project Settings -> API -> Project URL
# SUPABASE_KEY: Project Settings -> API -> service_role key (KEEP SECRET, server-side only)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media

# CORS: comma-separated origins, or * for all
BACKEND_CORS_ORIGINS=*
